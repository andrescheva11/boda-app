{
  "name": "boda-app",
  "type": "module",
  "private": true,
  "scripts": {
    "css:build": "tailwindcss -i ./frontend/index.css -o ./frontend/compiled.css",
    "css:watch": "tailwindcss -i ./frontend/index.css -o ./frontend/compiled.css --watch",
    "dev": "bun run css:build && (bun run css:watch & bun --hot ./server.ts)",
    "build": "bun run css:build && bun build ./frontend/index.tsx --outdir ./dist --target browser",
    "start": "bun ./server.ts"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "vite": "^6.4.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1"
  }
}
